{
  "name": "rin",
  "version": "0.1.0",
  "description": "Local-first runtime for chat-connected agent workflows.",
  "license": "MIT",
  "homepage": "https://github.com/THE-cattail/rin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/THE-cattail/rin.git"
  },
  "bugs": {
    "url": "https://github.com/THE-cattail/rin/issues"
  },
  "keywords": [
    "agent",
    "chat",
    "cli",
    "local-first",
    "runtime",
    "tui"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "rin": "dist/index.js"
  },
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "README.zh-CN.md",
    "README.ja.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false && chmod +x dist/index.js",
    "test:unit": "node --test test/**/*.test.js",
    "test:repo": "node scripts/check-repo.mjs",
    "metrics": "node scripts/measure-baselines.mjs",
    "test": "npm run build && npm run test:unit && npm run test:repo",
    "check": "npm run test",
    "check:container": "sh scripts/check-in-container.sh",
    "prepare": "node .husky/install.mjs",
    "hooks:install": "node .husky/install.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@koishijs/plugin-adapter-telegram": "^4.5.11",
    "@koishijs/plugin-http": "^0.6.3",
    "@koishijs/plugin-proxy-agent": "^0.3.3",
    "@lancedb/lancedb": "^0.26.2",
    "@mariozechner/pi-coding-agent": "file:third_party/pi-mono/packages/coding-agent",
    "@mariozechner/pi-tui": "file:third_party/pi-mono/packages/tui",
    "@sinclair/typebox": "^0.34.41",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "koishi": "^4.18.11",
    "koishi-plugin-adapter-onebot": "^6.8.0",
    "markdown-it": "^14.1.1",
    "mem0ai": "^2.2.4",
    "sqlite3": "^5.1.7",
    "telegramify-markdown": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "husky": "^9.1.7",
    "typescript": "^5.8.2"
  }
}
